# Shell functions. Sourced from ~/.zshrc alongside ~/.aliases.
# Aliases (simple substitutions) live in ~/.aliases.
# Functions (anything with logic) live here.

# git diff with conditional side-by-side based on terminal width
unalias gd 2>/dev/null
function gd() {
  if [[ $(tput cols) -gt 120 ]]; then
    git -c delta.side-by-side=true diff "$@"
  else
    git diff "$@"
  fi
}

# publish a branch, create a PR, then open the PR in a browser
function ghpr() {
    git push -u origin $(git rev-parse --abbrev-ref HEAD)

    pr_command="gh pr create -a @me --fill"

    eval $pr_command
    gh pr view --web
}

# helper: run a command with a spinner
function _webr_spin() {
  local emoji="$1" msg="$2"
  shift 2
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0

  setopt local_options no_monitor
  local start=$SECONDS
  local logfile
  logfile=$(mktemp -t webr.XXXXXX)
  # Force plain progress so the captured log isn't a TUI-escape soup
  COMPOSE_PROGRESS=plain NO_COLOR=1 eval "$*" &> "$logfile" &
  local pid=$!

  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  %s %s %s" "${frames[$((i % 10 + 1))]}" "$emoji" "$msg"
    i=$((i + 1))
    sleep 0.08
  done
  wait "$pid"
  local rc=$?
  local elapsed=$((SECONDS - start))

  if [[ $rc -eq 0 ]]; then
    printf "\r  ✅ %s %s (%ds)\n" "$emoji" "$msg" "$elapsed"
    rm -f "$logfile"
  else
    printf "\r  ❌ %s %s (%ds)\n" "$emoji" "$msg" "$elapsed"
    # Bypass `cat=bat` alias so we don't trigger the pager on garbled output
    command cat "$logfile"
    printf "  📝 Full log: %s\n" "$logfile"
  fi
  return $rc
}

# restart web environment after switching branches
function webr() {
  setopt local_options no_monitor
  local is_primary=false
  [[ "$(basename "$PWD")" == "persona-web" ]] && is_primary=true

  if $is_primary; then
    _webr_spin "🛑" "Stopping containers..." "docker compose --profile primary down"
  else
    _webr_spin "🛑" "Stopping containers..." "printf '%s\n' y | docker compose rm -s -v"
  fi

  # `p checkout fix` in the primary mutates the tracked docker-compose.yml and
  # blocks branch checkouts. The primary's docker-compose.override.yml already
  # provides the multi-instance patches, so only run the fix step in secondaries.
  if ! $is_primary; then
    _webr_spin "🔧" "Fixing docker compose config..." "p checkout fix"
  fi
  _webr_spin "📦" "Installing dependencies..." "docker compose run --user root --rm web bash -c 'bundle install && yarn install'"
  _webr_spin "🗃️"  "Running migrations..." "docker compose run --user root --rm web bash -c 'bundle exec rails db:migrate && bundle exec rails db:migrate RAILS_ENV=test'"

  if $is_primary; then
    _webr_spin "🚀" "Starting containers..." "docker compose --profile primary up -d"
  else
    _webr_spin "🚀" "Starting containers..." "docker compose up -d"
  fi

  # wait for web with spinner
  local start=$SECONDS
  docker compose logs -f web 2>&1 | grep -m 1 "Use Ctrl-C to stop" > /dev/null &
  local pid=$!
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  %s ⏳ Waiting for web to be ready..." "${frames[$((i % 10 + 1))]}"
    i=$((i + 1))
    sleep 0.08
  done
  wait "$pid"
  local elapsed=$((SECONDS - start))
  printf "\r  ✅ ⏳ Waiting for web to be ready... (%ds)\n" "$elapsed"

  local dir=$(basename "$PWD")
  local port=3000
  if [[ "$dir" =~ persona-web-([0-9]+) ]]; then
    port=$((3000 + match[1]))
  fi

  echo ""
  echo "  🟢 Ready! http://localhost:${port}/dashboard"
}

# coder: create a new persona-web workspace named cody-workspace-<N>.
# Passes dotfiles_uri so chezmoi runs automatically on first boot.
# Usage: crc 1
function crc() {
  local num="${1:?Usage: crc <1-100>}"
  local workspace="cody-workspace-${num}"
  coder create "$workspace" \
    --template persona-web-devcontainer \
    --preset Default \
    --yes \
    --parameter "dotfiles_uri=git@github.com:cody-ma/dotfiles.git" \
    --parameter "artifactory_token=cody%40withpersona.com:${ARTIFACTORY_API_KEY}"
}

# coder: ssh into a workspace with local env vars forwarded into the remote shell.
# Accepts a number (cr 1 -> cody-workspace-1) or a full workspace name (cr cody).
# Env vars not set locally are forwarded as empty (harmless).
function cr() {
  local arg="${1:-1}"
  local workspace
  if [[ "$arg" =~ ^[0-9]+$ ]]; then
    workspace="cody-workspace-${arg}"
  else
    workspace="$arg"
  fi
  coder ssh \
    --env BUILDKITE_API_TOKEN="$BUILDKITE_API_TOKEN" \
    --env BUILDKITE_ORGANIZATION_SLUG="$BUILDKITE_ORGANIZATION_SLUG" \
    --env ARTIFACTORY_API_KEY="$ARTIFACTORY_API_KEY" \
    --env ARTIFACTORY_USER="$ARTIFACTORY_USER" \
    --env CODER_WORKSPACE_NAME="$workspace" \
    "$workspace"
}
