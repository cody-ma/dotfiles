# docker compose commands that take an arg
alias dc='docker compose'
alias dcd='printf "%s\n" y | docker compose rm -s -v'
alias dcu='docker compose up -d'
alias dcr='docker compose restart'
alias dcl='docker compose logs --tail=10 -f -t'

# docker aliases
alias dcdp='docker compose --profile primary down;'
alias dcup='docker compose --profile primary up -d;'
alias dcrc='docker compose run --user root --rm web bundle exec rails console;'
alias dcps="docker compose ps --format json |  jq -r '[.Service, .Status] | @tsv'| column -t -s$'\t'";
alias dcweb='docker compose run --user root --rm web /bin/bash'
alias dcvite='docker compose run --user root --rm vite /bin/bash'
alias bundled='docker compose run --user root --rm web bash -c "bundle install && yarn install"'
alias migrated='docker compose run --user root --rm web bash -c "bundle exec rails db:migrate && bundle exec rails db:migrate RAILS_ENV=test"'

